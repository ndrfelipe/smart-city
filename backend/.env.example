# Configurações de Banco de Dados
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgresql://user:password@localhost:5432/smart_city

# Chave secreta do Flask para sessões e CSRF
# Gere uma nova usando: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui

# Configurações do Redis
REDIS_URL=redis://localhost:6379/0

# Chave secreta para assinatura de tokens JWT
# Gere uma nova usando: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=sua_chave_jwt_aqui
